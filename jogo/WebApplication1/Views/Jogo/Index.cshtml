@model IEnumerable<WebApplication1.Models.Jogo>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Imagem)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Titulo)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.IdGenero)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Genero)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(model => item.Imagem)
            </td>
            <td>
                @Html.DisplayFor(model => item.Titulo)
            </td>
            <td>
                @Html.DisplayFor(model => item.IdGenero)
            </td>
            <td>
                @Html.DisplayFor(model => item.Genero)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.IdJogo">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.IdJogo">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.IdJogo">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
